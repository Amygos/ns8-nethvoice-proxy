# NAT-mode e2e environment for podman-compose.
#
# Distinct loopback addresses model a "behind NAT" deployment:
#   PUBLIC_IP  = 192.0.2.1       advertise-only (TEST-NET-1, no socket bound)
#   PRIVATE_IP = 127.0.0.3       LAN socket Kamailio binds to (5060/6060)
#   SERVICE_IP = 127.0.0.4       internal service socket (5060)
#
# INTERNAL_NETWORK = 127.0.0.5/32 → only 127.0.0.5 counts as LAN; 127.0.0.2
# remains "WAN" and is therefore classified as "in" by Kamailio.
IMAGE_TAG=latest

PUBLIC_IP=192.0.2.1
PRIVATE_IP=127.0.0.3
SERVICE_IP=127.0.0.4
SERVICE_NET=127.0.0.5/32
LOCALNETWORKS=127.0.0.5/32
BEHIND_NAT=true
ENV=prod

RTP_PORT_MIN=30200
RTP_PORT_MAX=30300

KML_SERVER_HEADER=Nethesis SBC E2E NAT
KML_UA_HEADER=Nethesis SBC E2E NAT
KML_SIP_URL=e2e.local
KML_INTERNAL_NETWORK=127.0.0.5/32
DEFAULT_CONTACT=e2e.local

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kamailio
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
