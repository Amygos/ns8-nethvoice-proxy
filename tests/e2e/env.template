# E2E test environment for podman-compose
# Override IMAGE_TAG to test a different release; default = latest from ghcr.io.
IMAGE_TAG=latest

# Loopback addressing — Kamailio listens on 127.0.0.1, SIPp UAC will use 127.0.0.2
PUBLIC_IP=127.0.0.1
PRIVATE_IP=127.0.0.1
SERVICE_IP=127.0.0.1
# Fake non-loopback CIDR so 127.0.0.2 (SIPp UAC) is treated as EXTERNAL by Kamailio
SERVICE_NET=198.51.100.0/24
LOCALNETWORKS=198.51.100.0/24
BEHIND_NAT=false
ENV=prod

# RTP port range (kept small to limit container/host noise)
RTP_PORT_MIN=30000
RTP_PORT_MAX=30100

# Kamailio headers / endpoints
KML_SERVER_HEADER=Nethesis SBC E2E
KML_UA_HEADER=Nethesis SBC E2E
KML_SIP_URL=e2e.local
KML_INTERNAL_NETWORK=198.51.100.0/24
DEFAULT_CONTACT=e2e.local

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kamailio
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
